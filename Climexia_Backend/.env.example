# ── SERVER ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── DATABASE ─────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/climexia_db
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/climexia_db

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=climexia_access_secret_change_in_production_2026!
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=climexia_refresh_secret_change_in_production_2026!
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ─────────────────────────────────────────────────
FRONTEND_URL=https://climexia-saurabh.netlify.app
ADMIN_PANEL_URL=http://localhost:3001

# ── EMAIL (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@climexia.in
SMTP_PASS=your_smtp_app_password
FROM_EMAIL=noreply@climexia.in
FROM_NAME=Climexia Technologies

# ── UPLOAD ───────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_PATH=./uploads

# ── RATE LIMITING ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── SEED SUPER ADMIN ─────────────────────────────────────
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@climexia.in
SUPER_ADMIN_PHONE=9999999999
SUPER_ADMIN_PASSWORD=Climexia@Super2026!